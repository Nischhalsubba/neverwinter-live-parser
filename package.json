{
  "name": "neverwinter-live-parser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Windows-only local Neverwinter combat log parser with a minimal Electron dashboard.",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/main/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 nodemon --watch dist-electron --ext js,mjs --exec \"electron dist-electron/main/main.js\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "test": "vitest run",
    "preview": "vite preview",
    "extract:nwhub": "node scripts/extract-nw-hub-classes.mjs",
    "extract:nwhub:artifacts": "node scripts/extract-nw-hub-artifacts.mjs"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "electron-store": "^10.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "nodemon": "^3.1.9",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.1",
    "wait-on": "^8.0.3"
  }
}
