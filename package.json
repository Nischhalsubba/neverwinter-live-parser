{
  "name": "neverwinter-live-parser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": "Archew",
  "license": "MIT",
  "description": "Windows-only local Neverwinter combat log parser with a minimal Electron dashboard.",
  "main": "dist-electron/desktop/runtime/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/desktop/runtime/main.js && node scripts/dev-electron.mjs",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "dist:win-unpacked": "npm run build && electron-builder --win dir",
    "dist:win-portable": "npm run build && electron-builder --win portable",
    "test": "vitest run",
    "preview": "vite preview",
    "extract:nwhub": "node scripts/extract-nw-hub-classes.mjs",
    "extract:nwhub:artifacts": "node scripts/extract-nw-hub-artifacts.mjs"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "electron-store": "^10.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "nodemon": "^3.1.9",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.archew.neverwinter-live-parser",
    "productName": "Neverwinter Live Parser",
    "asar": true,
    "compression": "store",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "public/**",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Neverwinter-Live-Parser-Portable-${version}.${ext}"
    }
  }
}
